# Reddit OAuth2 (only needed for live ingest, not for .zst replay)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=brand-crisis-monitor/0.1 by your_username
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_CLIENT_ID=brand-crisis-monitor
TOPIC_RAW_SUBMISSIONS=reddit.raw.submissions
TOPIC_RAW_COMMENTS=reddit.raw.comments
TOPIC_SCORED=reddit.scored
TOPIC_AGGREGATES=reddit.aggregates
TOPIC_ALERTS=reddit.alerts

# Flink (local mini-cluster runs inside the python process)
FLINK_PARALLELISM=2

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=brandcrisis
POSTGRES_USER=brand
POSTGRES_PASSWORD=brand

# Sentiment model:
#   "vader"  — built-in, no download required (default)
#   "onnx"   — run scripts/export_model.py first
SENTIMENT_BACKEND=vader
ONNX_MODEL=model/artifacts/sentiment.int8.onnx
TOKENIZER_DIR=model/artifacts/tokenizer
SENTIMENT_MODEL_ID=cardiffnlp/twitter-roberta-base-sentiment-latest
ORT_THREADS=1

# Dashboard
DASHBOARD_API=http://localhost:8000
